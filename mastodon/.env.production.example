# ── Instance ──────────────────────────────────────────────────────────────────
LOCAL_DOMAIN=mastodon.reseau.local:8443
WEB_DOMAIN=mastodon.reseau.local:8443
SINGLE_USER_MODE=false
RAILS_ENV=production
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# ── Secrets — générer avec : openssl rand -hex 64 ────────────────────────────
SECRET_KEY_BASE=CHANGE_ME
OTP_SECRET=CHANGE_ME

# ── VAPID — générer avec : make generate-vapid ───────────────────────────────
VAPID_PRIVATE_KEY=CHANGE_ME
VAPID_PUBLIC_KEY=CHANGE_ME

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=mastodon_db
DB_PORT=5432
DB_NAME=mastodon_production
DB_USER=mastodon
DB_PASS=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://mastodon_redis:6379

# ── Mail (désactivé) ──────────────────────────────────────────────────────────
SMTP_SERVER=localhost
SMTP_PORT=25

# ── OIDC / Keycloak ───────────────────────────────────────────────────────────
OIDC_ENABLED=true
OIDC_DISPLAY_NAME=Keycloak SSO
OIDC_DISCOVERY=true
OIDC_ISSUER=https://keycloak.reseau.local:8443/realms/reseau
OIDC_SCOPE=openid,profile,email
OIDC_UID_FIELD=sub
OIDC_CLIENT_ID=mastodon
OIDC_CLIENT_SECRET=CHANGE_ME
OIDC_REDIRECT_URI=https://mastodon.reseau.local:8443/auth/auth/openid_connect/callback
OIDC_SECURITY_ASSUME_EMAIL_IS_VERIFIED=true
OIDC_PROMPT=login
OMNIAUTH_ONLY=true

# ── ActiveRecord Encryption ───────────────────────────────────────────────────
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=CHANGE_ME

# ── Misc ──────────────────────────────────────────────────────────────────────
TRUSTED_PROXY_IP=172.33.0.0/16
IP_RETENTION_PERIOD=31556952
SESSION_RETENTION_PERIOD=31556952
