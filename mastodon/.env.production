# ── Instance ──────────────────────────────────────────────────────────────────
LOCAL_DOMAIN=mastodon.reseau.local
WEB_DOMAIN=mastodon.reseau.local
SINGLE_USER_MODE=false
RAILS_ENV=production
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# ── Secrets (regenerate with: openssl rand -hex 64) ──────────────────────────
SECRET_KEY_BASE=b3d02d5e6f7a8c9b0e1f2d3a4c5b6e7f8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3
OTP_SECRET=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0

# VAPID keys: run `make generate-vapid` to fill these in
VAPID_PRIVATE_KEY=r70iIr-WjeRFqwxKCKGoA-0g3OipxynB__E3Jkktj5Y
VAPID_PUBLIC_KEY=BJZPQOuKR2gTYSSTeSk2Luhj_hCZlm549FeeT6VwTnVLSGdYk6-UwSn3GSIs7F4DmzVi3xwUIXbNk1hkXP3_RRw

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=mastodon_db
DB_PORT=5432
DB_NAME=mastodon_production
DB_USER=mastodon
DB_PASS=mastodon
DB_SSLMODE=require
DB_SSLROOTCERT=/usr/local/share/ca-certificates/reseau-local-ca.crt

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:redispassword@mastodon_redis:6379

# ── Mail (disabled — all emails captured, never sent) ─────────────────────────
SMTP_SERVER=localhost
SMTP_PORT=25

# ── OIDC / Keycloak ───────────────────────────────────────────────────────────
OIDC_ENABLED=true
OIDC_DISPLAY_NAME=Keycloak SSO
OIDC_DISCOVERY=true
OIDC_ISSUER=https://keycloak.reseau.local/realms/reseau
OIDC_SCOPE=openid,profile,email
OIDC_UID_FIELD=sub
OIDC_CLIENT_ID=mastodon
OIDC_CLIENT_SECRET=mastodon-secret
OIDC_REDIRECT_URI=https://mastodon.reseau.local/auth/auth/openid_connect/callback
OIDC_SECURITY_ASSUME_EMAIL_IS_VERIFIED=true
OIDC_PROMPT=login
OMNIAUTH_ONLY=true

# ── ActiveRecord Encryption (required since Mastodon 4.3) ────────────────────
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=VKAUKhRo0ZE7X4IO4IegQiIULvXakOUI
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=56ICD1VYxHBkP4ZRmawQc5SNmZIKeLKq
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=2tDdNQRZa02kC0yO87TqMqNEIKLnpQfW

# ── Misc ──────────────────────────────────────────────────────────────────────
TRUSTED_PROXY_IP=172.33.0.0/16
IP_RETENTION_PERIOD=31556952
SESSION_RETENTION_PERIOD=31556952

# ── Sécurité & Confidentialité ────────────────────────────────────────────────
AUTHORIZED_FETCH=true
DISALLOW_UNAUTHENTICATED_API_ACCESS=true
LIMITED_FEDERATION_MODE=true
